# Шаблон конфигурации. Скопируйте в .env и заполните значения:
#   cp .env.example .env

# --- Обязательные ----------------------------------------------------------

# Токен Telegram-бота. Получить у @BotFather.
BOT_TOKEN=

# Ключ шифрования паролей в users.db.
# Сгенерировать:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Потеря ключа = пароли пользователей не восстановить.
ENCRYPTION_KEY=

# --- Опциональные ----------------------------------------------------------

# Прокси для запросов к сервисам СПбГУТ (lk.sut.ru и т.д.).
# Telegram при этом ходит напрямую. Если не задан — запросы в ЛК идут напрямую.
# ALL_PROXY=socks5://user:pass@host:port

# Уровень логирования. По умолчанию INFO.
# DEBUG включать только для отладки — раздувает логи.
# LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR

# HTML-дампы страниц ЛК для отладки парсеров. По умолчанию ВЫКЛ (opt-in).
# Включайте только когда чините парсер; смотреть дампы — в папке debug_dumps/.
# DEBUG_DUMPS=1            # 1 — включить (по умолчанию 0)
# DEBUG_DUMPS_KEEP=30      # сколько последних дампов хранить

# Лимит попыток входа (защита от перебора пароля).
# LOGIN_RATE_LIMIT=5
# LOGIN_RATE_WINDOW_SEC=300

# Параллелизм и задержки запросов в ЛК (антибот).
# LK_CONCURRENCY=1
# LK_LOGIN_DELAY_SEC=1.5
# LK_LOGIN_JITTER_SEC=1.0

# TTL кэша расписания групп (часы). Старше — при запросе группы кэш
# обновляется в фоне, пользователю сразу отдаётся текущая версия.
# TIMETABLE_TTL_HOURS=6

# Telegram ID администраторов (через запятую) — кому слать алерт о поломке
# парсера ЛК. Свой ID можно узнать у @userinfobot. Пусто — алерты не шлются.
# ADMIN_IDS=123456789,987654321
# PARSER_ALERT_WINDOW_MIN=30      # окно подсчёта сбоёв, мин
# PARSER_ALERT_THRESHOLD=3        # порог: сбои у скольких разных юзеров → алерт
# PARSER_ALERT_COOLDOWN_MIN=60    # пауза между алертами, мин

# Heartbeat-файл для Docker healthcheck (см. healthcheck.py, docker-compose.yml).
# HEARTBEAT_FILE=/tmp/satanbot_heartbeat
# HEARTBEAT_MAX_AGE_SEC=120   # старше — контейнер считается нездоровым
